<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="context.jellyfin.downloader" name="Jellyfin Local Downloader" version="1.0.0" provider-name="You">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="main.py">
                <label>Download file</label>
                <visible>String.IsEqual(ListItem.DBType,movie) | String.IsEqual(ListItem.DBType,episode) | String.IsEqual(ListItem.DBType,season) | String.IsEqual(ListItem.DBType,tvshow)</visible>
            </item>
        </menu>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Bypass Android TV USB Restrictions</summary>
        <description>Downloads media locally to USB drives from Jellyfin. Supports Movies, Episodes, Seasons, and full TV Shows with unwatched filtering.</description>
        <platform>all</platform>
    </extension>
</addon>